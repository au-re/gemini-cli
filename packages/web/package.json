{
  "name": "@google/gemini-cli-web",
  "version": "0.1.21",
  "description": "Gemini CLI Web Edition - Browser-based terminal interface",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/google-gemini/gemini-cli.git"
  },
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@google/gemini-cli-core": "file:../core",
    "@google/genai": "1.13.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "isomorphic-git": "^1.27.1",
    "ignore": "^7.0.0"
  },
  "devDependencies": {
    "@google/gemini-cli-test-utils": "file:../test-utils",
    "@types/node": "^20.11.24",
    "@playwright/test": "^1.46.0",
    "@vitest/ui": "^3.1.1",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "vite": "^5.4.2",
    "vitest": "^3.1.1",
    "jsdom": "^26.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}